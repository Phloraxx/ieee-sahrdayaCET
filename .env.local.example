# =============================================================================
# IEEE Sahrdaya Website - Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Appwrite Configuration
# -----------------------------------------------------------------------------
# Appwrite Endpoint (Cloud: https://cloud.appwrite.io/v1 or Self-hosted URL)
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://backend.ieeesahrdaya.com/v1/

# Appwrite Project ID (from Appwrite Console → Settings → Project ID)
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your_project_id

# Appwrite API Key (Server-side only - for setup scripts and admin operations)
# Create in Appwrite Console → Settings → API Keys
# Required scopes: 
#   - databases.read, databases.write
#   - collections.read, collections.write
#   - documents.read, documents.write
#   - users.read, users.write
#   - teams.read, teams.write
#   - buckets.read, buckets.write
#   - files.read, files.write
APPWRITE_API_KEY=your_api_key

# -----------------------------------------------------------------------------
# Database & Collections
# -----------------------------------------------------------------------------
# Database ID (will be created by setup script)
NEXT_PUBLIC_APPWRITE_DATABASE_ID=ieee_sahrdaya_db

# Core Collection IDs (created by setup:appwrite script)
NEXT_PUBLIC_APPWRITE_SOCIETIES_COLLECTION_ID=societies
NEXT_PUBLIC_APPWRITE_EVENTS_COLLECTION_ID=events
NEXT_PUBLIC_APPWRITE_EXECOM_COLLECTION_ID=execom_members
NEXT_PUBLIC_APPWRITE_MEMBERS_COLLECTION_ID=members

# Event System Collection IDs (created by setup:event-system script)
NEXT_PUBLIC_APPWRITE_EVENT_REGISTRATIONS_COLLECTION_ID=event_registrations

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------
# Storage Bucket ID (for society images, event banners, etc.)
NEXT_PUBLIC_APPWRITE_SOCIETY_IMAGES_BUCKET_ID=society_images

# -----------------------------------------------------------------------------
# Email Configuration (SMTP)
# -----------------------------------------------------------------------------
# Email provider: "smtp" (default) or "resend"
EMAIL_PROVIDER=smtp

# SMTP Host (Gmail: smtp.gmail.com, Outlook: smtp-mail.outlook.com)
SMTP_HOST=smtp.gmail.com

# SMTP Port (587 for TLS, 465 for SSL)
SMTP_PORT=587

# Use secure connection (true for port 465)
SMTP_SECURE=false

# SMTP Authentication
# For Gmail: Use App Password (https://support.google.com/accounts/answer/185833)
SMTP_USER=events@ieeesahrdaya.com
SMTP_PASSWORD=your_app_password

# From address for emails
SMTP_FROM=IEEE Sahrdaya Events <events@ieeesahrdaya.com>

# Resend native API configuration (used when EMAIL_PROVIDER=resend)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM=IEEE Sahrdaya Events <events@ieeesahrdaya.com>

# Email Rate Limiting (optional - defaults shown)
EMAIL_RATE_LIMIT_PER_MINUTE=30
EMAIL_RATE_LIMIT_PER_HOUR=2000

# -----------------------------------------------------------------------------
# Payment Configuration
# -----------------------------------------------------------------------------
# Payment API Configuration
PAYMENT_API_URL=https://payment-api.nerdpixel.workers.dev/api
PAYMENT_WEBHOOK_SECRET=your-webhook-secret-here

# UPI ID for receiving payments
NEXT_PUBLIC_UPI_ID=your-upi-id
NEXT_PUBLIC_UPI_MERCHANT_NAME=IEEE Sahrdaya SB

# Legacy (kept for backward compatibility)
UPI_ID=your-upi-id

# -----------------------------------------------------------------------------
# Application URLs
# -----------------------------------------------------------------------------
# Production URL (used for QR codes, emails, and callbacks)
NEXT_PUBLIC_APP_URL=https://ieeesahrdaya.com


# -----------------------------------------------------------------------------
# Security & Authentication
# -----------------------------------------------------------------------------
# Cron job secret (for Vercel cron authentication)
# Generate with: openssl rand -hex 32
CRON_SECRET=your_cron_secret_here

# WebAuthn/Passkey Configuration
WEBAUTHN_RP_ID=ieeesahrdaya.com
WEBAUTHN_RP_NAME=IEEE Sahrdaya

# -----------------------------------------------------------------------------
# Logging & Monitoring (Optional)
# -----------------------------------------------------------------------------
# Log level: debug, info, warn, error
LOG_LEVEL=info

# Enable structured JSON logging (for production)
LOG_JSON=true

# -----------------------------------------------------------------------------
# Feature Flags (Optional)
# -----------------------------------------------------------------------------
# Enable payment feature
NEXT_PUBLIC_ENABLE_PAYMENTS=true

# Enable email notifications
NEXT_PUBLIC_ENABLE_EMAILS=true

# Enable passkey authentication
NEXT_PUBLIC_ENABLE_PASSKEYS=true
