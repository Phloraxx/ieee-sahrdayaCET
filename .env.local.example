# Appwrite Configuration
# Copy this file to .env.local and fill in your values

# Appwrite Endpoint (Cloud: https://cloud.appwrite.io/v1 or Self-hosted URL)
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1

# Appwrite Project ID (from Appwrite Console)
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your_project_id_here

# Appwrite API Key (Server-side only - for setup script)
# Create in Appwrite Console → Settings → API Keys
# Required scopes: databases.read, databases.write, teams.read, teams.write
APPWRITE_API_KEY=your_api_key_here

# Database ID (will be created by setup script)
NEXT_PUBLIC_APPWRITE_DATABASE_ID=ieee_sahrdaya_db

# Collection IDs (will be created by setup script)
NEXT_PUBLIC_APPWRITE_SOCIETIES_COLLECTION_ID=societies
NEXT_PUBLIC_APPWRITE_EVENTS_COLLECTION_ID=events
NEXT_PUBLIC_APPWRITE_EXECOM_COLLECTION_ID=execom_members

# Storage Bucket ID (optional - for file uploads in future)
NEXT_PUBLIC_APPWRITE_SOCIETY_IMAGES_BUCKET_ID=society_images
